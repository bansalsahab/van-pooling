# Database Configuration
POSTGRES_USER=vanpool
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=vanpool_db

# JWT Configuration
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Maps API Key (REQUIRED)
# Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_BROWSER_API_KEY=your_google_maps_browser_key_here
GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
GOOGLE_MAPS_REGION=IN
GOOGLE_MAPS_LANGUAGE=en-US

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Backend CORS Origins
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost"]

# Matching Engine Configuration
MATCHING_AGGREGATION_WINDOW_SECONDS=90
MATCHING_PICKUP_RADIUS_METERS=800
MATCHING_MAX_DETOUR_MINUTES=15

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Company Default Settings
DEFAULT_VAN_CAPACITY=8
DEFAULT_OPERATING_HOURS_START=07:00
DEFAULT_OPERATING_HOURS_END=22:00

# Notification Settings (Mock for development)
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
