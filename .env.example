# Van Pooling Platform Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED - Application will not start without these
# =============================================================================

# JWT Secret Key - MUST be a strong random value in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_SECURE_KEY

# =============================================================================
# GOOGLE MAPS - Required for routing and geocoding
# =============================================================================

# Server-side API key (for backend routing/geocoding)
GOOGLE_MAPS_API_KEY=your-server-api-key-here

# Browser API key (for frontend map rendering) - should have HTTP referrer restrictions
GOOGLE_MAPS_BROWSER_API_KEY=your-browser-api-key-here
VITE_GOOGLE_MAPS_API_KEY=your-browser-api-key-here
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Optional: Map styling ID
GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Region and language settings
GOOGLE_MAPS_REGION=IN
GOOGLE_MAPS_LANGUAGE=en-US

# =============================================================================
# OPENAI - Optional, enables AI copilot features
# =============================================================================

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_REASONING_EFFORT=low

# =============================================================================
# DATABASE - Configure based on your deployment
# =============================================================================

# SQLite (local development) - uncomment this line:
DATABASE_URL=sqlite:///./vanpool.db

# PostgreSQL (production) - uncomment and configure these:
# DATABASE_URL=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=vanpool
# POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
# POSTGRES_DB=vanpool_db

# =============================================================================
# REDIS - Required for background tasks and caching
# =============================================================================

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================

# Set to 'production' in production environments
ENVIRONMENT=development

# NEVER enable debug in production!
DEBUG=false

LOG_LEVEL=INFO

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# CORS origins - comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=true
AUTO_RUN_MIGRATIONS=true
